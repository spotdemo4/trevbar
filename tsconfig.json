{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "ags/gtk4",
    "lib": ["ES2023"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "paths": {
      "ags": ["./node_modules/ags/lib/index.ts"],
      "ags/*": ["./node_modules/ags/lib/*"],
      "gnim": ["./node_modules/gnim/dist/index.ts"],
      "gnim/*": ["./node_modules/gnim/dist/*"]
    },
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2020",
    "types": ["node"]
  }
}
