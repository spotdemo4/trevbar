{
  "$schema": "https://docs.renovatebot.com/renovate-global-schema.json",

  // self-hosted
  "onboarding": false,
  "requireConfig": "ignored",
  "platform": "forgejo",
  "endpoint": "https://trev.zip/api/v1",
  "repositories": ["llc/trevbar"],
  "allowedCommands": ["npm audit fix --omit optional"],

  // repository
  "extends": ["config:recommended"],
  "addLabels": ["dep"],
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["* * * * 0"], // sunday
    "skipInstalls": false,
    "postUpgradeTasks": {
      "commands": ["npm audit fix --omit optional"]
    }
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    },
    {
      "matchManagers": ["nix"],
      "addLabels": ["nix"]
    },
    {
      "matchManagers": ["github-actions"],
      "addLabels": ["actions"]
    },
    {
      "matchManagers": ["npm"],
      "rangeStrategy": "bump",
      "addLabels": ["node"],
      "postUpdateOptions": ["npmInstallTwice"]
    },
    {
      "matchManagers": ["npm"],
      "matchDepTypes": ["engines"],
      "enabled": false
    },
    {
      "matchManagers": ["npm"],
      "matchPackageNames": ["ags"],
      "enabled": false
    }
  ]
}
